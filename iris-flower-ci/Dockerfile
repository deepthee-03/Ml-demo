# =============================================================================
# Dockerfile — Iris Flower ML Classification (Pure Python CLI)
# =============================================================================
# Project type detected: Pure Python ML script (no web server)
#   - No Flask / FastAPI / Streamlit imports found in any source file
#   - Entry points: train.py (train + save model) → predict.py (inference)
#   - No port is exposed — this is a batch/CLI container, not a service
#
# Build:  docker build -t iris-flower:latest .
# Run:    docker run --rm --name iris-flower-container iris-flower:latest
# =============================================================================

# ── Base image ────────────────────────────────────────────────────────────────
# python:3.10-slim is the official Python 3.10 image built on Debian Bookworm
# with only the minimum OS packages needed to run Python.
# 'slim' is ~50 MB vs ~900 MB for the full image — critical for fast CI pulls.
# We do NOT use 'alpine' because scikit-learn requires C extensions that
# are painful to build on musl libc (Alpine's libc); slim avoids that entirely.
FROM python:3.10-slim

# ── Image metadata ────────────────────────────────────────────────────────────
# LABEL instructions are key=value pairs stored in the image's metadata.
# They appear in `docker inspect` and help teams identify images in registries.
LABEL maintainer="deepthee.saravanan@kasadara.com"
LABEL project="iris-flower-ci"
LABEL description="Iris Flower Species Classification — Logistic Regression"
LABEL version="1.0"
LABEL python_version="3.10"

# ── Runtime environment variables ─────────────────────────────────────────────
# Setting all three in one ENV layer saves one image layer vs three separate
# ENV instructions.
#
# PYTHONDONTWRITEBYTECODE=1
#   Stops Python from writing .pyc files to disk inside the container.
#   Those files are useless in a container (no second run to benefit from them)
#   and just add unnecessary bytes to the writable container layer.
#
# PYTHONUNBUFFERED=1
#   Forces Python's stdout/stderr to be flushed immediately rather than
#   buffering output. Without this, Jenkins/Docker log drivers may show no
#   output at all until the container exits — making live log streaming work.
#
# PIP_NO_CACHE_DIR=1
#   Prevents pip from storing downloaded packages in a cache directory
#   (~/.cache/pip). In a Docker build, that cache is discarded anyway when the
#   layer is committed, so caching just wastes space inside the image layer.
#
# PIP_DISABLE_PIP_VERSION_CHECK=1
#   Suppresses the "new version of pip available" warning that would otherwise
#   pollute every build log.
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# ── Working directory ─────────────────────────────────────────────────────────
# /app is the standard convention for application code in Docker containers.
# WORKDIR creates the directory if it doesn't exist and sets it as the CWD for
# all subsequent RUN, COPY, CMD, and ENTRYPOINT instructions.
WORKDIR /app

# ── Install dependencies — separate layer for build-cache efficiency ──────────
# COPY requirements.txt BEFORE copying the rest of the source code.
# Docker builds images layer by layer. If only source code changes (not
# requirements.txt), Docker reuses the cached pip-install layer and skips
# re-downloading packages — making iterative builds dramatically faster.
COPY requirements.txt .

# Single RUN instruction = single image layer.
# Chaining commands with && inside one RUN avoids creating extra layers.
#   pip install --upgrade pip  → avoids dependency resolver bugs in old pip
#   pip install -r requirements.txt → installs scikit-learn, joblib, numpy, pytest
RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# ── Copy only required source files ──────────────────────────────────────────
# We deliberately copy ONLY the two files the container needs to run.
# train.py   → trains the model, saves iris_model.pkl
# predict.py → loads iris_model.pkl, runs inference on sample inputs
#
# Intentionally excluded:
#   test_model.py  → tests run in Jenkins before the image is built
#   README.md      → documentation, irrelevant at runtime
#   iris_model.pkl → trained fresh inside the container on every run
#   reports/       → generated by pytest in Jenkins, not needed here
#   .github/       → CI config, irrelevant to runtime
#   entrypoint.sh  → not used; CMD below drives execution directly
COPY train.py predict.py ./

# ── Security: run as a non-root user ─────────────────────────────────────────
# Docker containers run as root by default — a security risk if the container
# is ever compromised. We create a dedicated low-privilege user 'mluser' and
# switch to it. This follows the principle of least privilege.
RUN useradd --create-home --shell /bin/bash mluser && \
    chown -R mluser:mluser /app

USER mluser

# ── Default command ───────────────────────────────────────────────────────────
# CMD (exec form with sh -c) runs both scripts in sequence as the container's
# default process. Using sh -c with && means:
#   1. python train.py runs first — trains the model, saves iris_model.pkl
#   2. Only if train.py exits with code 0 does python predict.py run — loads
#      iris_model.pkl and prints predictions for sample inputs
# If train.py fails, && short-circuits and predict.py is never attempted,
# producing a clear non-zero exit code that Docker and Jenkins can detect.
#
# Why CMD instead of ENTRYPOINT here?
#   ENTRYPOINT is ideal when the container wraps a single executable.
#   CMD is the right choice for a multi-step script sequence that runs and
#   exits — it is simpler, requires no external shell script file, and works
#   identically on Docker Desktop (Windows) and Linux Jenkins agents.
CMD ["sh", "-c", "python train.py && python predict.py"]
